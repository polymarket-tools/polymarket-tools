{
  "name": "n8n-nodes-polymarket",
  "version": "0.1.0",
  "description": "Polymarket nodes for n8n workflow automation",
  "license": "MIT",
  "homepage": "https://github.com/polymarket-tools/polymarket-tools",
  "repository": {
    "type": "git",
    "url": "https://github.com/polymarket-tools/polymarket-tools.git",
    "directory": "packages/n8n-nodes"
  },
  "keywords": ["n8n-community-node-package", "n8n", "polymarket", "prediction-market", "trading"],
  "main": "dist/nodes/Polymarket/Polymarket.node.js",
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": ["dist/credentials/PolymarketApi.credentials.js"],
    "nodes": [
      "dist/nodes/Polymarket/Polymarket.node.js",
      "dist/nodes/PolymarketTrigger/PolymarketTrigger.node.js"
    ]
  },
  "dependencies": {
    "@polymarket-tools/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "n8n-workflow": ">=1.72.0"
  }
}
