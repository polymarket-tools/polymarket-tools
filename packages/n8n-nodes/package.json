{
  "name": "n8n-nodes-polymarket-tools",
  "version": "1.1.3",
  "description": "n8n community node for Polymarket prediction markets - trading with EIP-712 signing, real-time prices, whale tracking, AI agent tools, and workflow templates",
  "license": "MIT",
  "homepage": "https://github.com/polymarket-tools/polymarket-tools",
  "repository": {
    "type": "git",
    "url": "https://github.com/polymarket-tools/polymarket-tools.git",
    "directory": "packages/n8n-nodes"
  },
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "n8n-nodes",
    "n8n-community-node",
    "polymarket",
    "prediction-markets",
    "prediction-market",
    "crypto",
    "trading",
    "trading-bot",
    "betting",
    "event-contracts",
    "defi",
    "blockchain",
    "eip-712",
    "ai-agent",
    "ai-trading",
    "workflow-automation",
    "market-data",
    "whale-tracking"
  ],
  "main": "dist/nodes/Polymarket/Polymarket.node.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/PolymarketApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Polymarket/Polymarket.node.js",
      "dist/nodes/PolymarketTrigger/PolymarketTrigger.node.js"
    ]
  },
  "dependencies": {
    "@polymarket-tools/core": "^0.1.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "n8n-workflow": ">=1.72.0"
  }
}
